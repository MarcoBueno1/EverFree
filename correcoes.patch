diff --git a/qml/components/FileListItem.qml b/qml/components/FileListItem.qml
--- a/qml/components/FileListItem.qml
+++ b/qml/components/FileListItem.qml
@@ -8,7 +8,7 @@ Item {
     height: visible ? 56 : 0
     visible: matchesFilter
 
-    property string filePath: model.filePath
